generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Таблиці які вимагає NextAuth — не чіпай їх структуру
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("student")  // student | admin
  accounts      Account[]
  sessions      Session[]
  results       Result[]  // зв'язок з результатами
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Наша таблиця — додаємо userId
model Result {
  id        String   @id @default(cuid())
  lessonId  String
  score     Int
  total     Int
  createdAt DateTime @default(now())
  userId    String?              // хто проходив (опціонально поки)
  user      User?   @relation(fields: [userId], references: [id])
}